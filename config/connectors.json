{
  "connectors": {
    "sherlock": {
      "name": "Sherlock",
      "type": "username_enum",
      "binary": "sherlock",
      "install": "pip3 install sherlock-project",
      "accepts": ["username"],
      "outputs": ["account"],
      "timeout": 120000,
      "priority": 1,
      "parallel": true,
      "parse_mode": "stdout_lines",
      "health_check": "sherlock --version",
      "args_template": "{username} --print-found --timeout 15 --json /dev/stdout",
      "enabled": true
    },
    "holehe": {
      "name": "Holehe",
      "type": "email_enum",
      "binary": "holehe",
      "install": "pip3 install holehe",
      "accepts": ["email"],
      "outputs": ["account"],
      "timeout": 90000,
      "priority": 1,
      "parallel": true,
      "parse_mode": "stdout_json",
      "health_check": "holehe --version",
      "args_template": "{email} --only-used --no-color",
      "enabled": true
    },
    "maigret": {
      "name": "Maigret",
      "type": "username_deep",
      "binary": "maigret",
      "install": "pip3 install maigret",
      "accepts": ["username"],
      "outputs": ["account", "profile_data"],
      "timeout": 300000,
      "priority": 2,
      "parallel": true,
      "parse_mode": "json_file",
      "health_check": "maigret --version",
      "args_template": "{username} --json flat --timeout 30",
      "enabled": true
    },
    "theharvester": {
      "name": "theHarvester",
      "type": "domain_recon",
      "binary": "theHarvester",
      "install": "pip3 install theHarvester",
      "accepts": ["domain"],
      "outputs": ["email", "subdomain", "ip"],
      "timeout": 180000,
      "priority": 1,
      "parallel": true,
      "parse_mode": "xml_output",
      "health_check": "theHarvester -h",
      "args_template": "-d {domain} -b all -f /dev/stdout",
      "enabled": true
    },
    "amass": {
      "name": "Amass",
      "type": "subdomain_enum",
      "binary": "amass",
      "install": "go install -v github.com/owasp-amass/amass/v4/...@master",
      "accepts": ["domain"],
      "outputs": ["subdomain", "ip", "asn"],
      "timeout": 600000,
      "priority": 2,
      "parallel": true,
      "parse_mode": "json_lines",
      "health_check": "amass -version",
      "args_template": "enum -passive -d {domain} -json -",
      "enabled": true
    },
    "subfinder": {
      "name": "Subfinder",
      "type": "subdomain_enum",
      "binary": "subfinder",
      "install": "go install -v github.com/projectdiscovery/subfinder/v2/cmd/subfinder@latest",
      "accepts": ["domain"],
      "outputs": ["subdomain"],
      "timeout": 120000,
      "priority": 1,
      "parallel": true,
      "parse_mode": "stdout_lines",
      "health_check": "subfinder -version",
      "args_template": "-d {domain} -silent -json",
      "enabled": true
    },
    "shodan": {
      "name": "Shodan",
      "type": "ip_recon",
      "binary": "shodan",
      "install": "pip3 install shodan",
      "accepts": ["ip", "domain"],
      "outputs": ["port", "service", "vulnerability", "banner"],
      "timeout": 60000,
      "priority": 1,
      "parallel": true,
      "parse_mode": "json_api",
      "health_check": "shodan info",
      "args_template": "host {target}",
      "api_key_env": "SHODAN_API_KEY",
      "enabled": true
    },
    "censys": {
      "name": "Censys",
      "type": "cert_recon",
      "binary": "censys",
      "install": "pip3 install censys",
      "accepts": ["domain", "ip"],
      "outputs": ["certificate", "subdomain", "service"],
      "timeout": 60000,
      "priority": 2,
      "parallel": true,
      "parse_mode": "json_api",
      "health_check": "censys --version",
      "args_template": "search hosts '{target}'",
      "api_key_env": "CENSYS_API_ID",
      "enabled": true
    },
    "phoneinfoga": {
      "name": "PhoneInfoga",
      "type": "phone_recon",
      "binary": "phoneinfoga",
      "install": "go install github.com/sundowndev/phoneinfoga/v2@latest",
      "accepts": ["phone"],
      "outputs": ["carrier", "location", "line_type", "account"],
      "timeout": 60000,
      "priority": 1,
      "parallel": true,
      "parse_mode": "json_output",
      "health_check": "phoneinfoga version",
      "args_template": "scan -n {phone} --json",
      "enabled": true
    },
    "h8mail": {
      "name": "h8mail",
      "type": "breach_lookup",
      "binary": "h8mail",
      "install": "pip3 install h8mail",
      "accepts": ["email"],
      "outputs": ["breach", "credential"],
      "timeout": 120000,
      "priority": 1,
      "parallel": true,
      "parse_mode": "json_output",
      "health_check": "h8mail --version",
      "args_template": "-t {email} --json",
      "enabled": true
    },
    "whatsmyname": {
      "name": "WhatsMyName",
      "type": "username_enum",
      "binary": "whatsmyname",
      "install": "pip3 install whatsmyname",
      "accepts": ["username"],
      "outputs": ["account"],
      "timeout": 90000,
      "priority": 2,
      "parallel": true,
      "parse_mode": "json_output",
      "health_check": "whatsmyname --version",
      "args_template": "-u {username}",
      "enabled": true
    },
    "socialscan": {
      "name": "socialscan",
      "type": "availability_check",
      "binary": "socialscan",
      "install": "pip3 install socialscan",
      "accepts": ["username", "email"],
      "outputs": ["account"],
      "timeout": 60000,
      "priority": 3,
      "parallel": true,
      "parse_mode": "stdout_table",
      "health_check": "socialscan --version",
      "args_template": "{target}",
      "enabled": true
    },
    "photon": {
      "name": "Photon",
      "type": "web_crawler",
      "binary": "photon",
      "install": "pip3 install photon",
      "accepts": ["url", "domain"],
      "outputs": ["url", "email", "social_link", "file"],
      "timeout": 300000,
      "priority": 3,
      "parallel": true,
      "parse_mode": "file_output",
      "health_check": "photon --version",
      "args_template": "-u https://{target} -o /tmp/cyclops_photon_{target} --json",
      "enabled": true
    },
    "ghunt": {
      "name": "GHunt",
      "type": "google_osint",
      "binary": "ghunt",
      "install": "pip3 install ghunt",
      "accepts": ["email"],
      "outputs": ["profile_data", "google_service", "review", "photo"],
      "timeout": 120000,
      "priority": 2,
      "parallel": false,
      "parse_mode": "stdout_json",
      "health_check": "ghunt --version",
      "args_template": "email {email} --json",
      "enabled": true
    },
    "nmap": {
      "name": "Nmap",
      "type": "port_scan",
      "binary": "nmap",
      "install": "brew install nmap",
      "accepts": ["ip", "domain"],
      "outputs": ["port", "service", "os_fingerprint"],
      "timeout": 600000,
      "priority": 2,
      "parallel": true,
      "parse_mode": "xml_output",
      "health_check": "nmap --version",
      "args_template": "-sV -sC -oX - {target}",
      "enabled": true
    },
    "dnsrecon": {
      "name": "DNSrecon",
      "type": "dns_enum",
      "binary": "dnsrecon",
      "install": "pip3 install dnsrecon",
      "accepts": ["domain"],
      "outputs": ["dns_record", "subdomain", "ip"],
      "timeout": 180000,
      "priority": 2,
      "parallel": true,
      "parse_mode": "json_output",
      "health_check": "dnsrecon --version",
      "args_template": "-d {domain} -j /dev/stdout",
      "enabled": true
    },
    "github": {
      "name": "GitHub",
      "type": "code_platform",
      "binary": null,
      "native": true,
      "accepts": ["username"],
      "outputs": ["account", "email", "person", "repository", "organization", "url"],
      "timeout": 60000,
      "priority": 1,
      "parallel": true,
      "enabled": true
    },
    "dns_native": {
      "name": "DNS-Native",
      "type": "dns_enum",
      "binary": null,
      "native": true,
      "accepts": ["domain"],
      "outputs": ["ip", "subdomain", "dns_record", "email", "domain"],
      "timeout": 120000,
      "priority": 1,
      "parallel": true,
      "enabled": true
    },
    "whois_native": {
      "name": "WHOIS-Native",
      "type": "domain_registration",
      "binary": null,
      "native": true,
      "accepts": ["domain"],
      "outputs": ["domain", "email", "person", "organization"],
      "timeout": 30000,
      "priority": 1,
      "parallel": true,
      "enabled": true
    },
    "crt_sh": {
      "name": "crt.sh",
      "type": "certificate_transparency",
      "binary": null,
      "native": true,
      "accepts": ["domain"],
      "outputs": ["subdomain", "certificate"],
      "timeout": 60000,
      "priority": 1,
      "parallel": true,
      "enabled": true
    },
    "haveibeenpwned": {
      "name": "HaveIBeenPwned",
      "type": "breach_lookup",
      "binary": null,
      "native": true,
      "accepts": ["email"],
      "outputs": ["breach", "domain"],
      "timeout": 30000,
      "priority": 1,
      "parallel": true,
      "api_key_env": "HIBP_API_KEY",
      "enabled": true
    },
    "web_scraper": {
      "name": "WebScraper",
      "type": "web_intelligence",
      "binary": null,
      "native": true,
      "accepts": ["url", "domain"],
      "outputs": ["email", "account", "phone", "url", "technology"],
      "timeout": 30000,
      "priority": 2,
      "parallel": true,
      "enabled": true
    },
    "wayback": {
      "name": "Wayback",
      "type": "historical_archive",
      "binary": null,
      "native": true,
      "accepts": ["domain"],
      "outputs": ["url", "subdomain", "email"],
      "timeout": 60000,
      "priority": 2,
      "parallel": true,
      "enabled": true
    },
    "ip_api": {
      "name": "IP-API",
      "type": "ip_geolocation",
      "binary": null,
      "native": true,
      "accepts": ["ip"],
      "outputs": ["ip", "organization", "domain"],
      "timeout": 15000,
      "priority": 1,
      "parallel": true,
      "enabled": true
    },
    "emailrep": {
      "name": "EmailRep",
      "type": "email_reputation",
      "binary": null,
      "native": true,
      "accepts": ["email"],
      "outputs": ["email", "account", "breach"],
      "timeout": 15000,
      "priority": 1,
      "parallel": true,
      "enabled": true
    },
    "hunter": {
      "name": "Hunter",
      "type": "email_finder",
      "binary": null,
      "native": true,
      "accepts": ["domain", "email"],
      "outputs": ["email", "person", "organization"],
      "timeout": 15000,
      "priority": 1,
      "parallel": true,
      "api_key_env": "HUNTER_API_KEY",
      "enabled": true
    },
    "virustotal": {
      "name": "VirusTotal",
      "type": "threat_intelligence",
      "binary": null,
      "native": true,
      "accepts": ["domain", "ip", "url"],
      "outputs": ["domain", "ip", "subdomain", "dns_record", "url"],
      "timeout": 30000,
      "priority": 1,
      "parallel": true,
      "api_key_env": "VIRUSTOTAL_API_KEY",
      "enabled": true
    },
    "securitytrails": {
      "name": "SecurityTrails",
      "type": "dns_intelligence",
      "binary": null,
      "native": true,
      "accepts": ["domain", "ip"],
      "outputs": ["subdomain", "ip", "dns_record", "domain", "email", "organization"],
      "timeout": 30000,
      "priority": 1,
      "parallel": true,
      "api_key_env": "SECURITYTRAILS_API_KEY",
      "enabled": true
    }
  },
  "execution": {
    "max_parallel": 8,
    "retry_attempts": 2,
    "retry_delay_ms": 5000,
    "global_timeout": 900000,
    "output_dir": "/tmp/cyclops_runs"
  },
  "api_keys": {
    "shodan": { "env": "SHODAN_API_KEY" },
    "censys_id": { "env": "CENSYS_API_ID" },
    "censys_secret": { "env": "CENSYS_API_SECRET" },
    "hunter": { "env": "HUNTER_API_KEY" },
    "virustotal": { "env": "VIRUSTOTAL_API_KEY" },
    "securitytrails": { "env": "SECURITYTRAILS_API_KEY" }
  }
}
